.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ---------- Testing / Coverage ----------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- OpenGL / GPU ----------
*.spv
*.spirv

# ---------- Logs / Debug ----------
*.log
debug_frames/

# ---------- Data / large files ----------
*.hdr
*.exr
*.fits
data/
!config/
